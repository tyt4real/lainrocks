<!DOCTYPE html>
<html lang="en">
    <head>
        {% block head %}
            <meta charset="UTF-8" />
            <meta name="viewport" content="width=device-width, initial-scale=1.0" />
            <meta name="description" content="lain.rocks, the c00l place on the internet" />
            <meta name="keywords" content="lain, xmpp, xmpp server, im, imageboard, textboard, oiled, up, niggas, aggresively, making, out" />
            <meta name="author" content="tyt4real" />
            <link rel="icon" type="image/x-icon" href="../images/favicon.ico" />
            <link rel="preconnect" href="https://fonts.googleapis.com" />
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
            <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
            <link id="account-css" href="../css/account.css" rel="stylesheet"/>
            <link id="theme-css" href="../css/lainrocks.css" rel="stylesheet" />
            <title>lain.rocks | {% block title %}{% endblock %}</title>
        {% endblock %}
    </head>
    <body>

        <div class="scanlines" aria-hidden="true"></div>

        <header class="site-header">
            <div class="site-header__inner">
                <div class="site-header__brand">
                    <a href="./?page=home" class="site-header__title">lain.rocks</a>
                    <span class="site-header__sub">The (hopefully) cool place on the internet</span>
                </div>
                <p class="site-header__quote">「どこに行ったって、人はつながっているのよ。」</p>
            </div>
        </header>

        <div id="content">{% block content %}{% endblock %}</div>

        <img src="../images/yotsuba.png" class="deco-corner hide-on-mobile" id="yotsuba" alt="" aria-hidden="true" />

        <footer class="site-footer">
            {% block footer %}
                <div class="site-footer__inner">
                    <div class="site-footer__info">
                        <p>Let's all love Lain. Copyleft 2025</p>
                        <p>For all abuse complaints, contact us here: <a href="mailto:tyt4real@protonmail.com">tyt4real@protonmail.com</a></p>
                        <div id="logo">
                            <svg id="Warstwa_2" data-name="Warstwa 2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 246.92 95.7">
  <defs>
    <style>
      .cls-1 {
        font-size: 15.87px;
      }

      .cls-1, .cls-2 {
        font-family: Coolvetica-Regular, Coolvetica;
      }

      .cls-3 {
        letter-spacing: 0em;
      }

      .cls-2 {
        font-size: 6px;
      }

      .cls-4 {
        letter-spacing: -.03em;
      }

      .cls-5 {
        font-family: ToxigenesisRg-Bold, Toxigenesis;
        font-size: 21.08px;
        font-weight: 700;
      }

      .cls-6 {
        fill: none;
        stroke: #000;
        stroke-miterlimit: 10;
        stroke-width: 5px;
      }

      .cls-7 {
        letter-spacing: -.04em;
      }

      .cls-8 {
        letter-spacing: 0em;
      }
    </style>
  </defs>
  <text class="cls-5" transform="translate(61.69 33.76) scale(1.29 1)"><tspan class="cls-8" x="0" y="0">R</tspan><tspan x="18.28" y="0">OCK</tspan></text>
  <text class="cls-1" transform="translate(150.74 35.4) scale(1.14 1)"><tspan x="0" y="0">p</tspan><tspan class="cls-4" x="8.3" y="0">r</tspan><tspan x="12.92" y="0">oductions</tspan></text>
  <path class="cls-6" d="M246.92,40.87h-87.35l13.16,25.48-22.28-19.07,9.35,37.19-19.17-25.19-9.01,11.77s-14.32-12.71-14.32-13.42-77.36,30.37-77.36,30.37l22.4-21.19-21.01-1.41,18.44-6.59L13.39,40.87h46.39L22.86,8.44l36.92,15.77,8.25.52"/>
  <text class="cls-2" transform="translate(63.539 39.5178) scale(2.851 1)"><tspan x="0" y="0">LAIN.ROC</tspan><tspan class="cls-7" x="23.82" y="0">K</tspan><tspan class="cls-3" x="27.21" y="0">S</tspan></text>
  <path d="M100.05,26c0,.11-1.64-.2-2.5.69-.86.9-.57,2.63-.68,2.63-.1,0,.2-1.73-.65-2.63-.85-.89-2.5-.58-2.5-.69,0-.11,1.64.2,2.5-.69.87-.91.56-2.67.66-2.67s-.21,1.76.66,2.67c.86.89,2.5.58,2.5.69Z"/>
  <path d="M171.97,31.53c0,.05-.89-.1-1.35.35-.47.45-.31,1.31-.37,1.31-.06,0,.11-.86-.35-1.31-.46-.45-1.35-.29-1.35-.35,0-.05.89.1,1.35-.35.47-.45.3-1.33.36-1.33s-.11.88.36,1.33c.46.44,1.35.29,1.35.35Z"/>
  <path d="M220.5,31.53c0,.05-.89-.1-1.35.35-.47.45-.31,1.31-.37,1.31-.06,0,.11-.86-.35-1.31-.46-.45-1.35-.29-1.35-.35,0-.05.89.1,1.35-.35.47-.45.3-1.33.36-1.33s-.11.88.36,1.33c.46.44,1.35.29,1.35.35Z"/>
</svg>
                        </div>
                    </div>
                    <div class="site-footer__theme">
                        <span class="theme-label">Theme</span>
                        <div class="theme-selector">
                            <button class="theme-btn" data-theme="lainrocks">Default lainrocks</button>
                            <button class="theme-btn" data-theme="yotsuba">Yotsuba</button>
                            <button class="theme-btn" data-theme="cyberpunk">Cyberpunk</button>
                        </div>
                    </div>
                </div>
            {% endblock %}
        </footer>

        <script src="../js/styleinit.js"></script>
        <script src="../js/themeManager.js"></script>
    </body>
</html>
