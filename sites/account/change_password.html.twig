{% extends "base.html.twig" %}
{% import "account/_form.html.twig" as form %}

{% block title %}Change Password{% endblock %}

{% block content %}
{{ renderNavbar() }}

<div class="page page--account">
    <div class="acct-wrap">

        <div class="acct-header">
            <h1 class="acct-title">Change password</h1>
            <p class="acct-sub">Your new password will apply to all lain.rocks services.</p>
        </div>

        {{ form.flash(flash) }}

        <div class="card acct-card">
            <h2 class="card__heading">Change password</h2>
            <form method="POST" action="?page=account&action=change-password" class="acct-form" novalidate>
                {{ form.field('Current password', 'current_password', 'password', '', '', true) }}
                {{ form.field('New password',     'new_password',     'password', '', '', true) }}
                {{ form.field('Confirm new password', 'confirm_password', 'password', '', '', true) }}
                <div class="acct-actions">
                    <button type="submit" class="acct-btn">Update password →</button>
                    <a class="acct-link" href="?page=account&action=profile">← Back to profile</a>
                </div>
            </form>
        </div>

    </div>
</div>
{% endblock %}
