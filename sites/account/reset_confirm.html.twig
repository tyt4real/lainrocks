{% extends "base.html.twig" %}
{% import "account/_form.html.twig" as form %}

{% block title %}Set New Password{% endblock %}

{% block content %}
{{ renderNavbar() }}

<div class="page page--account">
    <div class="acct-wrap">

        <div class="acct-header">
            <h1 class="acct-title">Set new password</h1>
            <p class="acct-sub">Enter the code from your reset email and choose a new password.</p>
        </div>

        {{ form.flash(flash) }}

        <div class="card acct-card">
            <h2 class="card__heading">Reset password</h2>
            <form method="POST" action="?page=account&action=reset-confirm" class="acct-form" novalidate>
                <input type="hidden" name="uid"   value="{{ uid }}">
                <input type="hidden" name="token" value="{{ token }}">
                {{ form.field('New password',     'new_password',     'password', '', '', true) }}
                {{ form.field('Confirm password', 'confirm_password', 'password', '', '', true) }}
                <div class="acct-actions">
                    <button type="submit" class="acct-btn">Set new password →</button>
                </div>
            </form>
        </div>

    </div>
</div>
{% endblock %}
